        flags: ST.ColumnFlag.DESCENDING_DEFAULT,

        synthesizer: (context, dn, entry) => {
            const v = entry.puavoDeviceHWInfo?.uptime;
            return (v === undefined) ? undefined : formatUptime(v);
        }
    },

    wifi: {
        title: "<%= t('columns.devices.wifi') %>",
        synthesizer: (context, dn, entry) => {
            const v = entry.puavoDeviceHWInfo?.wifi;
            return (v === undefined) ? undefined : { value: v };
        },
    },

    windows_installed: {
        title: "<%= t('columns.devices.windows_installed') %>",
        type: ST.ColumnType.BOOL,
        synthesizer: (context, dn, entry) => ST.outputBoolean(entry.puavoDeviceHWInfo?.windows?.is_installed),
    },

    windows_license: {
        title: "<%= t('columns.devices.has_windows_license') %>",
        type: ST.ColumnType.BOOL,
        synthesizer: (context, dn, entry) => {
            const v = entry.puavoDeviceHWInfo?.windows_license;

            if (v === undefined || v === null)
