function preparse(raw)
{
    const context = {
        entries: raw.devices,
        schools: raw.schools,
        releases: raw.releases,
        now: new Date(),
    };

    for (const [dn, device] of Object.values(context.entries)) {
        // Parse hardware infos so their values can be easily used in synthetic columns
        if (device.puavoDeviceHWInfo !== undefined)
            device.puavoDeviceHWInfo = JSON.parse(device.puavoDeviceHWInfo[0]);

        // Parse reset information
        if (device.puavoDeviceReset !== undefined)
            device.puavoDeviceReset = JSON.parse(device.puavoDeviceReset[0]);

<% if @is_servers %>
        // Required by the transformer
        device._school_id = -1;
<% else %>
        // Inject school PuavoIDs into the row entries, so that we can format the links correctly.
        // The transformer for the "school" attribute only retains the school name, not its ID.
        device._school_id = context.schools[device.puavoSchool[0]].id;
<% end %>

        // Inject expiration states, so the date object don't have to be repeatedly parsed everywhere.
        // This exists only in the preparse stage.
        device._expiration_timestamp = device.puavoDeviceExpirationTime ?
            new Date(ST.convertLDAPTimestampToISO8601String(device.puavoDeviceExpirationTime[0])) : null;
        device._has_expired = (device._expiration_timestamp !== null) && (context.now >= device._expiration_timestamp);
    }

    return context;
}

function postparse(context, transformed)
{
<% unless @is_servers %>
    // Inject the school IDs again
    for (let i = 0; i < context.entries.length; i++)
        transformed[i]._school_id = context.schools[context.entries[i][1].puavoSchool[0]].id;
<% end %>
}
