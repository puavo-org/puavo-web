    // puavo-pkg packages listing
    puavopkgs: {
        title: "<%= t('columns.devices.puavopkgs') %>",
        synthesizer: (context, dn, entry) => {
            const v = entry.puavoDeviceHWInfo?.puavopkgs?.installed;

            if (v === undefined || v === null)
                return undefined;

            let display = `<ul class="margin-0 padding-left-0 no-list-bullets">`,
                plain = [],
                sort = [];

            for (const [id, pkg] of Object.entries(v)) {
                let upstream = "-";

                if (pkg.upstream_pack) {
                    // Give word wrapping a chance to work
                    upstream = pkg.upstream_pack.match(/.{1,4}/g).join("<wbr>");
                }

                display += `<li><strong>${id}</strong><ul class="padding-left-25px">`;
                display += `<li><%= t('hwinfo.puavopkg.version') %>: ${pkg.version}</li>`;
                display += `<li><%= t('hwinfo.puavopkg.package_id') %>: <code>${pkg["package-id"].match(/.{1,4}/g).join("<wbr>")}</code></li>`;
                display += `<li><%= t('hwinfo.puavopkg.upstream_hash') %>: <code>${upstream}</code></li>`;
                display += `</ul></li>`

                // Include the hashes and IDs in the plain text string, so the column
                // is substring-searchable in filters. Not pretty, but it works.
                plain.push(`${id} ${pkg["package-id"]} ${pkg.upstream_pack ?? "-"}`);
                sort.push(`${id} ${pkg["package-id"]}`);
            }

            display += "</ul>";

            return {
                display: display,
                sort: sort.join(" "),
                filter: plain.join(" "),
                export: plain,
            };
        }
    },

