                    sort.push(`${image} ${release}`.toLowerCase());
                    export_.push(`${image} (${release})`);
                } else {
                    display.push(image);
                    filter.push(image);
                    sort.push(image);
                    export_.push(image);
                }
            }

            return {
                display: display,
                sort: sort.join(" "),
                filter: filter,
                export: export_
            };
