            return (v === undefined || v === null) ? undefined : ST.outputISO8601Timestamp(v);
        },
    },
<% end %>

<% if @is_organisation %>
<% unless @is_servers %>
    school: {
        title: "<%= t('columns.school') %>",
        synthesizer: (context, dn, entry) => { return { value: context.schools[entry.puavoSchool[0]].name } },
    },
<% end %>
<% end %>

<% if @is_servers %>
    schools: {
        title: "<%= t('columns.servers.schools') %>",
        flags: ST.ColumnFlag.ARRAY,
        synthesizer: (context, dn, entry) => {
            const schools = entry.puavoSchool;

            if (schools === undefined || schools === null)
                return undefined;

            let display = [],
                values = [];

            for (const dn of schools) {
                if (!(dn in context.schools))
                    continue;

                const school = context.schools[dn];

                display.push(`<a href="${school.link}">${school.name}</a>`);
                values.push(school.name);
            }

            return {
                display: display,
                sort: values.join(" "),
                filter: values,
                export: values,
            };
        },
    },
<% end %>

