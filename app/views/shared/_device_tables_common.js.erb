            return {
                display: v.replaceAll("\n", "<br>"),
                filter: v.replaceAll("\n", " "),
                sort: v.replaceAll("\n", " "),
                export: v,
            };
        },
    },

    xrandr: {
        attribute: "puavoDeviceXrandr",
        title: "<%= t('columns.devices.xrandr') %>",
        flags: ST.ColumnFlag.ARRAY,
    },
};

