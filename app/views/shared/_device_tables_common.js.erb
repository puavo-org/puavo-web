// A string containing a floating-point number, with a locate-specific digit separator
// (dot, comma) and ending in a '%'. Convert it to a saner format.
const manglePercentage = str => parseFloat(str.replaceAll(",", ".").replaceAll("%", ""));

// Like above, but for voltages
const mangleVoltage = str => parseFloat(str.replaceAll(",", ".").replaceAll("V", ""));

// Extracts the free disk space for a partition and formats it
const manglePartitionFree = (entry, field) => formatStorage(entry.puavoDeviceHWInfo?.free_space?.[field]);

function formatStorage(value)
{
    if (value === undefined)
        return undefined;

    return {
        // Display as megabytes, but use the raw value for others
        display: (value / 1048576).toFixed(0),
        sort: value,
        filter: value,
        export: value
    };
}

function formatRelease(context, image)
{
    if (image === undefined)
        return undefined;

    image = image.replace(".img", "");

    if (!(image in context.releases))
        return { value: image };

    const release = context.releases[image];

    return {
        display: `${image} <span class="releaseName">(${release})</span>`,
        filter: `${image} ${release}`,
        sort: `${image} ${release}`.toLowerCase(),
        export: `${image} (${release})`,
    };
}

// Formats the device uptime "nicely"
function formatUptime(seconds)
{
    let parts = [],
        s = seconds;

    // Days
    if (s >= 86400) {
        const d = Math.floor(s / 86400);

        parts.push(`${d}d`);
        s -= d * 86400;
    }

    // Hours
    if (s >= 3600) {
        const h = Math.floor(s / 3600);

        parts.push(`${h}h`);
        s -= h * 3600;
    }

    // Minutes
    if (s >= 60) {
        const m = Math.floor(s / 60);

        parts.push(`${m}m`);
        s -= m * 60;
    }

    // Seconds (avoid adding "0s" to the end, unless there are no other parts)
    if (s > 0 || parts.length == 0)
        parts.push(`${s}s`);

    return {
        display: parts.join(', '),
        filter: seconds,
        sort: seconds,
        export: seconds
    };
}

