    ram: {
        key: "ram",
        title: "<%= t('columns.devices.hwinfo_ram_size') %>",
        type: ST.ColumnType.NUMERIC,
        flags: ST.ColumnFlag.DESCENDING_DEFAULT | ST.ColumnFlag.F_STORAGE,
        synthesizer: (context, dn, entry) => {
            // For some reason, when I wrote the sysinfo collector tool back in 2017,
            // I used megabytes as the unit, instead of bytes. Too late to change that.
            // So use the memory slot information if it exists, and if not, then fallback
            // to the old raw number.
            if (entry.puavoDeviceHWInfo?.memory && entry.puavoDeviceHWInfo.memory.length > 0) {
                let total = 0;

                for (const s of entry.puavoDeviceHWInfo.memory) {
                    if ("bytes" in s)           // plain bytes
                        total += s.bytes;
                    else if ("size" in s)       // megabytes to bytes
                        total += s.size * 1024 * 1024;
                }

                return formatStorage(total);
            }

            if (entry.puavoDeviceHWInfo?.memorysize_mb) {
                // Fallback, but convert the value to bytes for formatStorage()
                return formatStorage(entry.puavoDeviceHWInfo.memorysize_mb * 1024 * 1024);
            }

            return undefined;
        },
    },

