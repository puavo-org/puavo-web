// A list of schools. Some columns and mass operations need access to a list of schools.
const SCHOOLS = {
<% @schools_list.each do |s| %>
    "<%= s[:id] %>": {
        dn: "<%= s[:dn] %>",
        name: "<%= s[:name] %>",
    },
<% end %>
};

// Localized user role names
const USER_ROLES = {
    owner: "<%= t('organisation_owner_role') %>",
    schooladmin: "<%= t('school_admin_role') %>",
    admin: "<%= t('puavoEduPersonAffiliation_admin') %>",
    teacher: "<%= t('puavoEduPersonAffiliation_teacher') %>",
    student: "<%= t('puavoEduPersonAffiliation_student') %>",
    staff: "<%= t('puavoEduPersonAffiliation_staff') %>",
    testuser: "<%= t('puavoEduPersonAffiliation_testuser') %>",
    parent: "<%= t('puavoEduPersonAffiliation_parent') %>",
    visitor: "<%= t('puavoEduPersonAffiliation_visitor') %>",
    unknown: "<%= t('unknown_role') %>",
};

// Localized group types
const GROUP_TYPES = {
    "teaching group": "<%= t('group_type.teaching group') %>",
    "course group": "<%= t('group_type.course group') %>",
    "year class": "<%= t('group_type.year class') %>",
    "administrative group": "<%= t('group_type.administrative group') %>",
    "archive users": "<%= t('group_type.archive users') %>",
    "other groups": "<%= t('group_type.other groups') %>",
};

const COLUMN_DEFINITIONS = {
    created: {
        attribute: "createTimestamp",
        title: "<%= t('columns.created') %>",
        type: ST.ColumnType.UNIXTIME,
        flags: ST.ColumnFlag.DESCENDING_DEFAULT,
    },

    devices: {
        title: "<%= t('columns.users.devices') %>",
        flags: ST.ColumnFlag.ARRAY,
        synthesizer: (context, dn, entry) => {
            const devices = context.devices?.[dn];

            if (devices === undefined)
                return undefined;

            let display = [],
                raw = [];

            for (const d of devices) {
                const s = context.schools[d.school_dn];

                display.push(`<a href="/devices/${d.school_id}/devices/${d.id}">${d.hostname}</a> (${s?.name ?? "?"})`);
                raw.push(d.hostname);
            }

            return {
                display: display.join("<br>"),
                sort: raw.join(" "),
                filter: raw.join(" ").toLowerCase(),
                export: raw
            };
        }
    },

    dnd: {
        attribute: "puavoDoNotDelete",
        title: "<%= t('columns.users.dnd') %>",
        type: ST.ColumnType.BOOL,
        defaultValue: false,
        alias: ["do_not_delete"],
    },

    eid: {
        attribute: "puavoExternalId",
        title: "<%= t('columns.users.eid') %>",
        alias: ["external_id"]
    },

    email: {
        attribute: "mail",
        title: "<%= t('columns.users.email') %>",
        flags: ST.ColumnFlag.ARRAY,
    },

    expiration: {
        attribute: "puavoEduPersonAccountExpirationTime",
        title: "<%= t('columns.users.expiration') %>",
        type: ST.ColumnType.UNIXTIME,

        transformer: (context, dn, entry) => {
            if (entry._expiration_timestamp === null)
                return undefined;

            // Highlight expired timestamps (the expiration timestamp and expiration flag are set in the preparser)
            const out = ST.outputISO8601Timestamp(entry._expiration_timestamp);

            if (entry._has_expired)
                out.display = `<span class="invalidData">${out.display}</span>`;

            return out;
        },

    },

    first: {
        attribute: "givenName",
        title: "<%= t('columns.users.first_names') %>",
        alias: ["first_name", "fn"],
    },

    // User's groups (synthetic column, does not exist in Puavo)
    groups: {
        title: "<%= t('columns.users.groups') %>",
        flags: ST.ColumnFlag.ARRAY,
        synthesizer: (context, dn, entry) => {
            let groups = [];

            if (context.userGroups.has(dn))
                for (const gid of context.userGroups.get(dn))
                    if (gid in context.groups)
                        groups.push(context.groups[gid]);

            const justNames = groups.map(g => g.name);

            return {
                display: groups.map(g => (g.link ? `<a href=\"${g.link}\">${g.name}</a>` : g.name) +
                                          ` (<small>${GROUP_TYPES[g.type] || "?"}</small>)`).join("<br>"),
                sort: justNames.join(",").toLowerCase(),
                filter: justNames.map(n => n.toLowerCase()),
                export: justNames
            };
        },
    },

    id: {
        attribute: "puavoId",
        title: "<%= t('columns.puavoid') %>",
        type: ST.ColumnType.NUMERIC,
        alias: ["puavoid"],
    },

    last: {
        attribute: "sn",
        title: "<%= t('columns.users.last_name') %>",
        alias: ["last_name", "ln"],
    },

    // This attribute exists in Puavo, but its value cannot be used as-is
    last_kerberos_auth_date: {
        title: "<%= t('columns.last_kerberos_auth_date') %>",
        type: ST.ColumnType.UNIXTIME,
        flags: ST.ColumnFlag.DESCENDING_DEFAULT | ST.ColumnFlag.F_DATEONLY,
        synthesizer: (context, dn, entry) => {
            if (!(entry.uid[0] in context.krb))
                return undefined;

            return ST.outputISO8601Timestamp(context.krb[entry.uid[0]], ST.ColumnFlag.F_DATEONLY);
        }
    },

    last_ldap_auth_date: {
        attribute: "authTimestamp",
        title: "<%= t('columns.last_ldap_auth_date') %>",
        type: ST.ColumnType.UNIXTIME,
        flags: ST.ColumnFlag.DESCENDING_DEFAULT | ST.ColumnFlag.F_DATEONLY,
    },

    learner_id: {
        attribute: "puavoLearnerId",
        title: "<%= t('columns.users.learner_id') %>",
        alias: ["lid"],
    },

    licenses: {
        attribute: "puavoLicenses",
        title: "<%= t('columns.users.licenses') %>",
        flags: ST.ColumnFlag.ARRAY,
        transformer: (context, dn, entry) => {
            const parsed = JSON.parse(entry.puavoLicenses[0]);
            const keys = Object.keys(parsed).sort();

            return ST.outputAsStandardArray(keys, false);
        }
    },

    locked: {
        attribute: "puavoLocked",
        title: "<%= t('columns.users.is_locked') %>",
        type: ST.ColumnType.BOOL,
        defaultValue: false,            // this is one of those weird quasi-ternary LDAP booleans (kinda our fault, though)
    },

    mfa: {
        attribute: "puavoMFAEnabled",
        title: "MFA?",
        type: ST.ColumnType.BOOL,
        defaultValue: false,            // ditto
    },

    modified: {
        attribute: "modifyTimestamp",
        title: "<%= t('columns.modified') %>",
        type: ST.ColumnType.UNIXTIME,
        flags: ST.ColumnFlag.DESCENDING_DEFAULT,
    },

    name: {
        attribute: "displayName",
        title: "<%= t('columns.users.full_name') %>",
        transformer: (context, dn, entry) => {
            const name = entry.displayName[0];
            let extra = "";

            if (entry._has_expired)
                extra += ` <i class="icon-clock" title="<%= t('users.index.expired_account') %>"></i>`;

            return {
                display: `<a href="/users/${context.schools[entry.puavoSchool[0]].id}/users/${entry.puavoId[0]}">${name}</a>${extra}`,
                filter: name,
                sort: name.toLowerCase(),
                export: name
            };
        },
    },

    notes: {
        attribute: "puavoNotes",
        title: "<%= t('columns.notes') %>",
        flags: ST.ColumnFlag.ARRAY,
        transformer: (context, dn, entry) => ST.outputAsStandardArray(entry.puavoNotes[0].replaceAll("\r", "").split("\n"), false),
    },

    p_email: {
        attribute: "puavoPrimaryEmail",
        title: "<%= t('columns.users.p_email') %>",
        flags: ST.ColumnFlag.F_NULLABLE,
    },

    phone: {
        attribute: "telephoneNumber",
        title: "<%= t('columns.users.phone') %>",
        flags: ST.ColumnFlag.ARRAY,
        alias: ["phone_number"],
    },

    pnumber: {
        attribute: "puavoEduPersonPersonnelNumber",
        title: "<%= t('columns.users.pnumber') %>",
    },

    role: {
        attribute: "puavoEduPersonAffiliation",
        title: "<%= t('columns.users.role') %>",
        flags: ST.ColumnFlag.ARRAY,
        transformer: (context, dn, entry) => {
            let plain = [...entry.puavoEduPersonAffiliation],
                nice = [...plain].map(r => USER_ROLES[r]),
                filtered = [...nice];

            // Additional roles (these are synthetic, they don't exist in Puavo, but they're useful)
            if (context.schoolAdmins.has(dn)) {
                plain.unshift("schooladmin");
                nice.unshift(`<span class="adminOrOwner">${USER_ROLES["schooladmin"]}</span>`);
                filtered.unshift(USER_ROLES["schooladmin"]);
            }

            if (context.owners.has(dn)) {
                plain.unshift("owner");
                nice.unshift(`<span class="adminOrOwner">${USER_ROLES["owner"]}</span>`);
                filtered.unshift(USER_ROLES["owner"]);
            }

            return {
                display: nice,
                filter: filtered,
                sort: filtered.join(",").toLowerCase(),
                export: plain
            };
        }
    },

    rrt: {
        attribute: "puavoRemovalRequestTime",
        title: "<%= t('columns.users.rrt') %>",
        type: ST.ColumnType.UNIXTIME,
        alias: ["removal_request_time"],
    },

<% if @is_organisation %>
    // Primary school
    school: {
        attribute: "puavoEduPersonPrimarySchool",
        title: "<%= t('columns.primary_school') %>",
        transformer: (context, dn, entry) => { return { value: context.schools[entry.puavoEduPersonPrimarySchool[0]].name } },
    },
<% end %>

    // All schools
    schools: {
        attribute: "puavoSchool",
        title: "<%= t('columns.users.other_schools') %>",
        flags: ST.ColumnFlag.ARRAY,
        transformer: (context, dn, entry) => {
            const primary = entry.puavoEduPersonPrimarySchool[0];
            let schools = [];

            for (const dn of entry.puavoSchool)
                if (dn != primary)
                    schools.push(context.schools[dn].name);

            return ST.outputAsStandardArray(schools, false);
        }
    },

    uid: {
        attribute: "uid",
        title: "<%= t('columns.users.uid') %>",
        alias: ["username"],
    },

    uuid: {
        attribute: "puavoUuid",
        title: "UUID",
        customCSS: "font-monospace",        // this makes these easier to read
    },

    v_email: {
        attribute: "puavoVerifiedEmail",
        title: "<%= t('columns.users.v_email') %>",
        flags: ST.ColumnFlag.ARRAY,
    },
