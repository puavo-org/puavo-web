    <th><%= t('users.index.mass_operations.set_expiration_times.set_to') %></th>
    <td>
        <div class="flex-cols gap-5px">
            <input type="datetime-local" id="time" autocomplete="off" step="1">

            <button type="button" id="clear"><%= t('expiration_times.clear') %></button>

            <select id="preset" autocomplete="off">
            <option value="" disabled selected hidden><%= t('expiration_times.presets') %></option>
            <%= expiration_time_presets %>
            </select>
        </div>
    </td>
</tr>`;

        this.container.querySelector("input#time").addEventListener("change", e => this.onChangeTime(e));
        this.container.querySelector("button#clear").addEventListener("click", () => this.onClear());
        this.container.querySelector("select#preset").addEventListener("change", e => this.onSelectPreset(e));
    }

    onChangeTime(e)
    {
        const d = e.target.value;

        if (d === null) {
            this.expirationTime = null;
            return;
        }

        // Local time -> UTC time
        const offset = new Date().getTimezoneOffset(),
              offsetString = `${offset < 0 ? "+" : "-"}${pad(Math.abs(offset) / 60, 2)}:${pad(Math.abs(offset) % 60, 2)}`;

        this.expirationTime = new Date(e.target.value + offsetString);
        console.log(this.expirationTime);
    }

    onClear()
    {
        this.container.querySelector("input#time").value = null;
        this.expirationTime = null;
    }

    onSelectPreset(e)
    {
        this.expirationTime = new Date(new Date().getTime() + (parseInt(e.target.value, 10) * 1000));
        this.setTime(this.expirationTime);
        e.target.value = "";
    }

    setTime(date)
    {
        this.container.querySelector("input#time").value =
            pad(date.getFullYear(), 4) + "-" +
            pad(date.getMonth() + 1) + "-" +
            pad(date.getDate()) + "T" +
            pad(date.getHours()) + ":" +
            pad(date.getMinutes()) + ":" +
            pad(date.getSeconds());
    }

    canProceed()
    {
        return true;
    }

    start()
    {
        for (const i of this.container.querySelectorAll("input, button, select"))
            i.disabled = true;
    }

    finish()
    {
        for (const i of this.container.querySelectorAll("input, button, select"))
            i.disabled = false;
    }

    getOperationParameters()
    {
        return {
            action: 'set_expiration_time',
            time: (this.expirationTime === null) ? null : Math.floor(this.expirationTime.getTime() / 1000)
        };
    }

    prepareItem(item)
    {
        // Refuse to lock non-deletable users
        if (item.dnd?.filter === true) {
            return {
                state: "error",
                message: "<%= t('users.index.mass_operations.set_expiration_times.dnd') %>"
            };
        }

        return { state: "ready" };
    }
};
<% end %>

