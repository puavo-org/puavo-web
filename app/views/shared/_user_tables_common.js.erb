function preparse(raw)
{
    let context = {
        entries: raw.users,
        groups: raw.groups,
        schools: raw.schools,
        devices: raw.devices,
        owners: new Set(raw.owners),
        krb: raw.krb_auth_times,
        now: new Date(),
    };

    // Reverse school admins mappping
    const schoolAdmins = new Map();

    for (const [schoolDN, userDNs] of Object.entries(raw.school_admins)) {
        for (const dn of userDNs) {
            if (!schoolAdmins.has(dn))
                schoolAdmins.set(dn, []);

            schoolAdmins.get(dn).push(schoolDN);
        }
    }

    context.schoolAdmins = schoolAdmins;

    // Construct a reverse group membership mapping. Instead of having objects of groups and group members,
    // turn them into a map of user's groups, so we can look them up fast.
    const userGroups = new Map();

    for (const [groupID, members] of Object.entries(raw.group_members)) {
        for (const dn of members) {
            if (!userGroups.has(dn))
                userGroups.set(dn, []);

            userGroups.get(dn).push(parseInt(groupID, 10));
        }
    }

    // Inject expiration states, so the date object don't have to be repeatedly parsed everywhere.
    // This exists only in the preparse stage.
    for (const [_, user] of Object.values(context.entries)) {
        user._expiration_timestamp = user.puavoEduPersonAccountExpirationTime ?
            new Date(ST.convertLDAPTimestampToISO8601String(user.puavoEduPersonAccountExpirationTime[0])) : null;
        user._has_expired = (user._expiration_timestamp !== null) && (context.now >= user._expiration_timestamp);
        //console.log(user._expiration_timestamp, user._has_expired);
    }

    context.userGroups = userGroups;

    return context;
}

function postparse(context, transformed)
{
    // Inject school PuavoIDs into the row entries, so that we can format the links correctly.
    // The transformer for the "school" attribute only retains the school name, not its ID.
    for (let i = 0; i < context.entries.length; i++)
        transformed[i]._school_id = context.schools[context.entries[i][1].puavoEduPersonPrimarySchool[0]].id;
}
